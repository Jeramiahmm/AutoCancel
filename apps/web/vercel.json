{
  "installCommand": "corepack enable && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @autocancel/web build",
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/inbox-sync",
      "schedule": "30 13 * * *"
    }
  ]
}
