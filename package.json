{
  "name": "autocancel-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "dev": "pnpm --filter @autocancel/web dev",
    "dev:web": "pnpm --filter @autocancel/web dev",
    "dev:mobile": "pnpm --filter @autocancel/mobile start",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @autocancel/web test:e2e",
    "format": "pnpm -r format"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  }
}
