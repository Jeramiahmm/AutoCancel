# Core app
DEMO_MODE=true
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-random-secret-in-production
APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autocancel

# Security
ENCRYPTION_KEY_BASE64=replace-with-base64-32-byte-key
CRON_SECRET=replace-with-long-secret

# Optional: Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Optional: Magic-link email login
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optional: AI extraction
OPENAI_API_KEY=

# Optional: Transactional email reminders
RESEND_API_KEY=

# Optional: Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM_MONTHLY=

# Optional: Push settings
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:security@yourdomain.com
EXPO_ACCESS_TOKEN=

# Optional: Monitoring
SENTRY_DSN=
