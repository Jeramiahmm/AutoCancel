# Core app
# Required in production
NEXTAUTH_URL=http://localhost:3000
# AUTH_URL is supported as an alias for NEXTAUTH_URL
AUTH_URL=http://localhost:3000
# Required in production
NEXTAUTH_SECRET=replace-with-strong-random-secret
# AUTH_SECRET is supported as an alias for NEXTAUTH_SECRET
AUTH_SECRET=replace-with-strong-random-secret
# Optional alias for callback URLs and app links (falls back to NEXTAUTH_URL/AUTH_URL)
APP_BASE_URL=http://localhost:3000
# Required in production
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autocancel

# OAuth callback URLs to register in providers:
# NextAuth Google login: <APP_BASE_URL>/api/auth/callback/google
# Native provider connect (dashboard): <APP_BASE_URL>/oauth/callback/google
# Native provider connect (dashboard): <APP_BASE_URL>/oauth/callback/microsoft

# Security
ENCRYPTION_KEY_BASE64=replace-with-base64-32-byte-key
CRON_SECRET=replace-with-long-secret

# Required in production for Google sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Optional: Magic-link email login
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optional: AI extraction
OPENAI_API_KEY=

# Optional: Transactional email reminders
RESEND_API_KEY=

# Optional: Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM_MONTHLY=

# Optional: Push settings
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:security@yourdomain.com
EXPO_ACCESS_TOKEN=

# Optional: Monitoring
SENTRY_DSN=
